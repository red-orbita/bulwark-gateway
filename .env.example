# Sentinel Gateway — Environment Configuration
# Copy this file to .env and fill in real values. NEVER commit .env to git.
#
# This file is used by docker-compose.yml for LOCAL DEVELOPMENT only.
# In Kubernetes, secrets are managed via K8s Secrets (see k8s/secrets/).

# ─── Backend (upstream LLM/Agent API) ───────────────────────────────────────
SENTINEL_BACKEND_URL=http://host.docker.internal:8000
SENTINEL_LOG_LEVEL=INFO
SENTINEL_FAIL_MODE=closed

# ─── Auth Secrets (CHANGE THESE — use: openssl rand -hex 32) ────────────────
SENTINEL_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
ADMIN_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
ADMIN_PASSWORD=change-me-use-strong-password

# ─── Optional users (CHANGE IN PRODUCTION) ──────────────────────────────────
SECURITY_PASSWORD=change-me-use-strong-password
AUDITOR_PASSWORD=change-me-use-strong-password

# ─── Admin Portal ───────────────────────────────────────────────────────────
ADMIN_DEBUG=false

# ─── Telemetry / SIEM Export ────────────────────────────────────────────────
SENTINEL_TELEMETRY_ENABLED=true
SENTINEL_TELEMETRY_BATCH_SIZE=100
SENTINEL_TELEMETRY_FLUSH_INTERVAL=1.0
SENTINEL_SIEM_STATS_FILE=shared/siem/siem_stats.json

# ─── IOC Feed API Keys (obtain from respective providers) ───────────────────
# Leave empty if not using threat intel feeds
SENTINEL_URLHAUS_KEY=
SENTINEL_THREATFOX_KEY=
SENTINEL_OTX_KEY=
SENTINEL_ABUSEIPDB_KEY=

# ─── Enrichment (optional — requires ML models) ────────────────────────────
SENTINEL_ENRICHMENT_ENABLED=false

# ─── ML Scanners (optional — requires ONNX models in ./models/) ─────────────
# Set INSTALL_ML=true when building the Docker image to include dependencies.
# Models: injection-classifier (~738MB), toxicity (~260MB)
# Download: python scripts/download-models.py
SENTINEL_ML_ENABLED=false
SENTINEL_ML_MODEL_DIR=models
SENTINEL_ML_BLOCKING=false
# Build arg for docker-compose:
INSTALL_ML=false

# ─── Redis ──────────────────────────────────────────────────────────────────
SENTINEL_REDIS_URL=redis://redis:6379/0

# ─── Grafana (docker-compose --profile full) ────────────────────────────────
GRAFANA_PASSWORD=change-me-use-strong-password
